--code3:training and detection code 

import pandas as pd
from sklearn.ensemble import IsolationForest
from sklearn.metrics import confusion_matrix, classification_report, accuracy_score, precision_score, recall_score, f1_score




df = pd.read_csv("behavioral_dataset.csv")


df = df.fillna(0)

# =========================
# Feature Engineering
# =========================
df["attack_score"] = (
    df["powershell_count"] * 3 +
    df["cmd_count"] * 2 +
    df["net_user_count"] * 5 +
    df["whoami_count"] * 3 +
    df["encoded_count"] * 4 +
    df["nop_count"] * 3 +
    df["getprocess_count"] * 2 +
    df["getservice_count"] * 2
)




feature_cols = [
    "total_events",
    "powershell_count",
    "cmd_count",
    "browser_count",
    "system_count",
    "editor_count",
    "explorer_count",
    "other_count",
    "whoami_count",
    "net_user_count",
    "encoded_count",
    "nop_count",
    "getprocess_count",
    "getservice_count",
    "event1_count",
    "event3_count",
    "event5_count",
    "event11_count",
    "event12_count",
    "event13_count",
    "event22_count",
    "avg_command_length",
    "max_command_length",
    "hour",
    "attack_score"
]

X = df[feature_cols]




model = IsolationForest(
    n_estimators=100,
    contamination=0.2,
    random_state=42
)

model.fit(X)




df["anomaly"] = model.predict(X)
df["anomaly"] = df["anomaly"].map({1: 0, -1: 1})




df.to_csv("behavioral_results.csv", index=False)

print("behavioral_results.csv created successfully")




print("\nAnomaly counts:")
print(df["anomaly"].value_counts())

print("\nDetected anomalous windows:")
print(df[df["anomaly"] == 1][[
    "time_window",
    "total_events",
    "powershell_count",
    "cmd_count",
    "browser_count",
    "system_count",
    "whoami_count",
    "net_user_count",
    "attack_score",
    "anomaly"
]].head(20))






df["true_label"] = (
    (df["powershell_count"] > 0) |
    (df["cmd_count"] > 0) |
    (df["net_user_count"] > 0) |
    (df["whoami_count"] > 0)
).astype(int)


cm = confusion_matrix(df["true_label"], df["anomaly"])

cm_df = pd.DataFrame(
    cm,
    index=["Actual Normal (0)", "Actual Suspicious (1)"],
    columns=["Predicted Normal (0)", "Predicted Anomaly (1)"]
)

print("\n" + "="*50)
print(" CONFUSION MATRIX ")
print("="*50)
print(cm_df)


accuracy = accuracy_score(df["true_label"], df["anomaly"])
precision = precision_score(df["true_label"], df["anomaly"])
recall = recall_score(df["true_label"], df["anomaly"])
f1 = f1_score(df["true_label"], df["anomaly"])

print("\n" + "="*50)
print(" PERFORMANCE METRICS ")
print("="*50)
print(f"{'Accuracy':<15}: {accuracy:.4f}")
print(f"{'Precision':<15}: {precision:.4f}")
print(f"{'Recall':<15}: {recall:.4f}")
print(f"{'F1-score':<15}: {f1:.4f}")


print("\n" + "="*50)
print(" CLASSIFICATION REPORT ")
print("="*50)
print(classification_report(df["true_label"], df["anomaly"]))
