--code2: encoding code 

import pandas as pd


df = pd.read_csv("dataset.csv")


df["process"] = df["process"].fillna("unknown").astype(str)
df["parent_process"] = df["parent_process"].fillna("unknown").astype(str)
df["command_line"] = df["command_line"].fillna("").astype(str)
df["user"] = df["user"].fillna("unknown").astype(str)


df["timestamp"] = pd.to_datetime(df["timestamp"], errors="coerce")


df = df.dropna(subset=["timestamp"])


df["time_window"] = df["timestamp"].dt.floor("1min")

# process lowercase
df["process_lower"] = df["process"].str.lower()
df["command_lower"] = df["command_line"].str.lower()


def classify_process(p):
    p = str(p).lower()

    if "powershell" in p:
        return "powershell"
    elif "cmd.exe" in p:
        return "cmd"
    elif "chrome" in p or "msedge" in p or "firefox" in p or "opera" in p:
        return "browser"
    elif (
        "svchost" in p
        or "system32\\services.exe" in p
        or "runtimebroker" in p
        or "searchapp" in p
        or "shellexperiencehost" in p
        or "textinputhost" in p
        or "dllhost" in p
        or "taskhostw" in p
        or "wmiadap" in p
        or "mpcmdrun" in p
    ):
        return "system"
    elif "notepad" in p or "wordpad" in p or "code.exe" in p:
        return "editor"
    elif "explorer.exe" in p:
        return "explorer"
    else:
        return "other"

df["process_category"] = df["process"].apply(classify_process)

# ===== Features على مستوى الحدث =====
df["is_powershell"] = df["process_category"].apply(lambda x: 1 if x == "powershell" else 0)
df["is_cmd"] = df["process_category"].apply(lambda x: 1 if x == "cmd" else 0)
df["is_browser"] = df["process_category"].apply(lambda x: 1 if x == "browser" else 0)
df["is_system"] = df["process_category"].apply(lambda x: 1 if x == "system" else 0)
df["is_editor"] = df["process_category"].apply(lambda x: 1 if x == "editor" else 0)
df["is_explorer"] = df["process_category"].apply(lambda x: 1 if x == "explorer" else 0)
df["is_other"] = df["process_category"].apply(lambda x: 1 if x == "other" else 0)

df["has_whoami"] = df["command_lower"].apply(lambda x: 1 if "whoami" in x else 0)
df["has_net_user"] = df["command_lower"].apply(lambda x: 1 if "net user" in x else 0)
df["has_encoded"] = df["command_lower"].apply(lambda x: 1 if "-enc" in x else 0)
df["has_nop"] = df["command_lower"].apply(lambda x: 1 if "-nop" in x else 0)
df["has_getprocess"] = df["command_lower"].apply(lambda x: 1 if "get-process" in x else 0)
df["has_getservice"] = df["command_lower"].apply(lambda x: 1 if "get-service" in x else 0)

# event_id رقمي
df["event_id"] = pd.to_numeric(df["event_id"], errors="coerce").fillna(0)

df["is_event_1"] = (df["event_id"] == 1).astype(int)
df["is_event_3"] = (df["event_id"] == 3).astype(int)
df["is_event_5"] = (df["event_id"] == 5).astype(int)
df["is_event_11"] = (df["event_id"] == 11).astype(int)
df["is_event_12"] = (df["event_id"] == 12).astype(int)
df["is_event_13"] = (df["event_id"] == 13).astype(int)
df["is_event_22"] = (df["event_id"] == 22).astype(int)

# command length
df["command_length"] = pd.to_numeric(df["command_length"], errors="coerce").fillna(0)


grouped = df.groupby("time_window").agg(
    total_events=("event_id", "count"),
    powershell_count=("is_powershell", "sum"),
    cmd_count=("is_cmd", "sum"),
    browser_count=("is_browser", "sum"),
    system_count=("is_system", "sum"),
    editor_count=("is_editor", "sum"),
    explorer_count=("is_explorer", "sum"),
    other_count=("is_other", "sum"),
    whoami_count=("has_whoami", "sum"),
    net_user_count=("has_net_user", "sum"),
    encoded_count=("has_encoded", "sum"),
    nop_count=("has_nop", "sum"),
    getprocess_count=("has_getprocess", "sum"),
    getservice_count=("has_getservice", "sum"),
    event1_count=("is_event_1", "sum"),
    event3_count=("is_event_3", "sum"),
    event5_count=("is_event_5", "sum"),
    event11_count=("is_event_11", "sum"),
    event12_count=("is_event_12", "sum"),
    event13_count=("is_event_13", "sum"),
    event22_count=("is_event_22", "sum"),
    avg_command_length=("command_length","mean"),
    max_command_length=("command_length", "max"),
).reset_index()


grouped["hour"] = grouped["time_window"].dt.hour


grouped.to_csv("behavioral_dataset.csv", index=False)

print("behavioral_dataset.csv created successfully")
print(grouped.head())
print("Number of windows:", len(grouped))
