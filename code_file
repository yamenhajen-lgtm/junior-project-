--code1: transform logs to dataset (.csv)

import json
import csv

input_file = "all_data.json"
output_file = "dataset.csv"

with open(input_file, "r") as f, open(output_file, "w", newline='', encoding="utf-8") as out:
    writer = csv.writer(out)

    writer.writerow([
        "event_id",
        "process",
        "parent_process",
        "command_line",
        "user",
        "timestamp",
        "command_length"
    ])

    for line in f:
        try:
            log = json.loads(line)

            provider = log.get("data", {}).get("win", {}).get("system", {}).get("providerName", "")

            if provider == "Microsoft-Windows-Sysmon":

                system = log.get("data", {}).get("win", {}).get("system", {})
                data = log.get("data", {}).get("win", {}).get("eventdata", {})

                event_id = system.get("eventID", "")


                process = data.get("image", "")
                parent = data.get("parentImage", "")
                command = data.get("commandLine", "")
                user = data.get("user", "")

                timestamp = log.get("timestamp", "")

                command_length = len(str(command).split())

                writer.writerow([
                    event_id,
                    process,
                    parent,
                    command,
                    user,
                    timestamp,
                    command_length
                ])

        except:
            continue
